{
    "name": "davidcolquhoun/monitor-exceptions-laravel",
    "description": "Light weight PHP exception monitoring for Laravel.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Monitor\\Exceptions\\": "src/"
        }
    },
    "authors": [
        {
            "name": "David Colquhoun",
            "email": "davidc@datasmugglers.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^12.0",
        "symfony/http-foundation": "^7.2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Monitor\\Exceptions\\MonitorExceptionsServiceProvider"
            ]
        }
    }
}
